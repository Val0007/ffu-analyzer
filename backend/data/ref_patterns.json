      ]
    },
    {
      "name": "FINISH_ITEM_INDEXED_WILDCARD",
      "short_label": "YTA.X",
      "regex": "\\b((?:FG|G|F)\\d{1,2}:xx)\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 12,
