{
  "version": 1,
  "doc_number_pattern": "[A-Z]-\\d{2}\\.\\d-\\d{4}",
  "ref_types": [
    {
      "name": "FORKLARING_SE",
      "short_label": "HÄNV",
      "regex": "(?:FÖRKLARING(?:AR)?|BETECKNINGAR|HÄNVISNINGAR?)\\s+SE\\s+(\\d{4}-[A-Z]{1,3}-\\d{2}\\.\\d+-\\d{5}|[A-Z]{1,3}-\\d{2}\\.\\d+-\\d{5}|[A-Z]{1,3}-[A-Z]{2,3})(?![A-ZÅÄÖ])",
      "capture_group": 1,
      "target_type": "doc_number",
      "priority": 1
    },
    {
      "name": "SE",
      "short_label": "SE",
      "regex": "SE\\s+(\\d{4}-[A-Z]{1,3}-\\d{2}\\.\\d+-\\d{5}|[A-Z]{1,3}-\\d{2}\\.\\d+-\\d{5}|[A-Z]{1,3}-[A-Z]{2,3})(?![A-ZÅÄÖ])",
      "capture_group": 1,
      "target_type": "doc_number",
      "priority": 2
    },
    {
      "name": "ENL",
      "short_label": "ENL",
      "regex": "(?:ENL\\.?|ENLIGT)\\s+(\\d{4}-[A-Z]{1,3}-\\d{2}\\.\\d+-\\d{5}|[A-Z]{1,3}-\\d{2}\\.\\d+-\\d{5}|[A-Z]{1,3}-[A-Z]{2,3})",
      "capture_group": 1,
      "target_type": "doc_number",
      "priority": 3
    },
    {
      "name": "ELEMENT_CODE",
      "short_label": "BYGD",
      "regex": "\\b([A-Z]{2,4}\\d{1,3})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 10,
      "filter_by_element_prefixes": true
    },
    {
      "name": "DOOR_PARTITION",
      "short_label": "DÖRR",
      "regex": "\\b((?:ISP|DS|GP|IP|FP|D)\\d{2}[A-Z]?)(?![A-Za-z0-9])(?!(?:-[A-Z]\\d{2}))",
      "capture_group": 1,
      "target_type": null,
      "priority": 11
    },
    {
      "name": "FINISH_CODE",
      "short_label": "YTA",
      "regex": "\\b([GF]\\d{1,2}[A-Z]?|(?:FG|G|F)\\d{1,2}:\\d{2})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 12
    },
    {
      "name": "DOC_NUMBER_FULL",
      "short_label": "RITN",
      "regex": "\\b([A-Z]-\\d{2}\\.\\d-\\d{4})\\b",
      "capture_group": 1,
      "target_type": "doc_number",
      "priority": 4,
      "examples": [
        "4021-FA-42.6-01252",
        "4021-SP-54.1-01010",
        "4021-K-20.4-01006"
      ]
    },
    {
      "name": "DOC_SUFFIX_CODE",
      "short_label": "RITN.K",
      "regex": "\\b((?!SS-EN|EN-ISO)[A-Z]{1,3}-[A-Z]{2,3})(?![A-Z])\\b",
      "capture_group": 1,
      "target_type": "doc_number",
      "priority": 4,
      "examples": [
        "SP-HF",
        "SP-TB",
        "K-HF"
      ]
    },
    {
      "name": "STANDARD",
      "short_label": "STND",
      "regex": "\\b(SS(?:F)?\\s*\\d{3,5}:\\d{1,4}(?:\\+\\w\\d:\\d{4})?)\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 5,
      "examples": [
        "SS 25268:2023",
        "SS 25268:2007+T1:2017",
        "SSF 200:6"
      ]
    },
    {
      "name": "GYPROC_DETAIL",
      "short_label": "GIPS",
      "regex": "\\b(Gyproc\\s*\\d+\\.\\d+\\.\\d+:\\d+(?:-\\d+)?)\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 6,
      "examples": [
        "Gyproc 3.1.51:202-211"
      ]
    },
    {
      "name": "ASSEMBLY_CODE_HYPHEN",
      "short_label": "MONT",
      "regex": "\\b((?:UVD|UHD)-\\d{1,3})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 6,
      "examples": [
        "UVD-112",
        "UHD-109"
      ]
    },
    {
      "name": "UNIT_GROUP_CODE",
      "short_label": "KOMP",
      "regex": "\\b(UPG\\s*\\d{1,2}[A-Z]?)\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 7,
      "examples": [
        "UPG15A",
        "UPG15B",
        "UPG23",
        "UPG20"
      ]
    },
    {
      "name": "FINISH_ITEM_INDEXED",
      "short_label": "YTA.P",
      "regex": "\\b((?:FG|G|F)\\d{1,2}:(?:\\d{2}|xx))\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 12,
      "examples": [
        "G4:01",
        "G2:15",
        "FG1:01"
      ]
    },
    {
      "name": "COLOR_CODE",
      "short_label": "FÄRG",
      "regex": "\\b(NCS\\s*S\\s*\\d{4}-[A-Z](?:\\d{2}[A-Z])?|RAL\\s*\\d{4})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 8,
      "examples": [
        "NCS S 0500-N",
        "NCS S 3050-R80B",
        "RAL 7045"
      ]
    },
    {
      "name": "PRODUCT_CODE_SH",
      "short_label": "PROD",
      "regex": "(?<!\\bSS)\\b([A-Z]{2}\\d{5}(?:-[A-Z])?)\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 9,
      "examples": [
        "SH11121-X",
        "SH42222-I",
        "SH43222-I"
      ]
    },
    {
      "name": "SPRINKLER_SYMBOL",
      "short_label": "SPR",
      "regex": "(?<![A-Z]\\d{2}-)\\b([A-Z]\\d{2})\\b(?!-[A-Z]\\d{2})",
      "capture_group": 1,
      "target_type": null,
      "priority": 9,
      "examples": [
        "A12",
        "B12",
        "E25",
        "I12",
        "F25"
      ]
    },
    {
      "name": "SHEET_INDEX",
      "short_label": "BLAD",
      "regex": "\\b([Aa][Kk]\\d{2})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 7,
      "examples": [
        "Ak21",
        "Ak01"
      ]
    },
    {
      "name": "ROOM_NUMBER",
      "short_label": "RUM",
      "regex": "\\b(\\d{4}:\\d{2})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 8,
      "examples": [
        "0808:01",
        "0850:01",
        "0860:02"
      ]
    },
    {
      "name": "PIPE_ROUTE",
      "short_label": "RÖR",
      "regex": "\\b(S\\d{2}L?-P\\d+)\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 8,
      "examples": [
        "S01-P5",
        "S01L-P5"
      ]
    },
    {
      "name": "SYSTEM_TAG",
      "short_label": "SYST",
      "regex": "\\b((?:VV|KV)\\d{2})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 8,
      "examples": [
        "VV01",
        "KV01"
      ]
    },
    {
      "name": "GRID_REF_PAIR",
      "short_label": "MODN",
      "regex": "\\b([A-Z]\\d{2}-[A-Z]\\d{2})\\b",
      "capture_group": 1,
      "target_type": null,
      "priority": 6,
      "examples": [
        "D01-E10"
      ]
    },
    {
      "name": "REBAR_MESH",
      "short_label": "ARM",
      "regex": "\\b(SL\\d{2,3}-R\\d{1,2})\\b",
